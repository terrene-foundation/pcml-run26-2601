# MLFP Course — Environment Variables
# Copy to .env and fill in any keys you need.

# ──────────────────────────────────────────────────────────────────────
# Module 6 LLMs — Ollama-first (no API keys, runs locally and on Colab)
# ──────────────────────────────────────────────────────────────────────
# M6 lessons (prompting, RAG, agents, governance, deployment) all call a
# local Ollama daemon. Local install: https://ollama.com/download.
# Colab notebooks install + start the daemon automatically in Cell 0.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Used by lesson 6.2/6.3 fine-tuning evaluation (the *served* baseline);
# training uses the HuggingFace base via SFT_BASE_MODEL below.
OLLAMA_FT_BASE_MODEL=qwen2.5:0.5b
# Optional override for the LLM-as-judge model used by the M6 diagnostics
# Observatory. Defaults to OLLAMA_CHAT_MODEL if unset.
# OLLAMA_JUDGE_MODEL=llama3.2:3b

# ──────────────────────────────────────────────────────────────────────
# Module 6 fine-tuning — HuggingFace base model for TRL/PEFT training
# ──────────────────────────────────────────────────────────────────────
# Lessons 6.2/6.3 train via Align (TRL/PEFT), which needs a HF repo id.
# After training, the GGUF export becomes the OLLAMA_FT_BASE_MODEL above.
SFT_BASE_MODEL=Qwen/Qwen2.5-0.5B-Instruct
HF_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — third-party providers
# ──────────────────────────────────────────────────────────────────────
# These are only consulted if the corresponding Ollama variable is unset.
# Leave blank for the default Ollama-only experience.
# OPENAI_API_KEY=
# OPENAI_PROD_MODEL=
# DEFAULT_LLM_MODEL=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Optional course infrastructure
# ──────────────────────────────────────────────────────────────────────
# Google Drive (optional — data loader uses public folder by default)
# GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# Database (optional — defaults to SQLite for exercises)
# DATABASE_URL=sqlite:///mlfp.db
